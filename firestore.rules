rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'anugoonk@gmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Role is read from the user's own (protected) doc. Trustworthy because
    // a user cannot change their own role/isAdmin fields (see /users update rule).
    function hasRole(roles) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function isSeller() {
      return isAdmin() || hasRole(['SELLER', 'ADMIN']);
    }

    // True if the update does NOT modify privileged fields.
    function notTouchingPrivileged() {
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'isAdmin']);
    }

    // True if `field` keeps the same value across an update (ownership immutability).
    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // Optional-safe size cap: passes if the field is absent or null, otherwise it
    // must be a string within maxLen bytes. Used to bound base64 images and free
    // text so a single document can't be abused (Firestore also caps docs at 1MB).
    function okSize(field, maxLen) {
      return !(field in request.resource.data)
        || request.resource.data[field] == null
        || (request.resource.data[field] is string && request.resource.data[field].size() <= maxLen);
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid
        && okSize('avatar', 1000000) && okSize('cover', 1000000)
        && okSize('bio', 2000) && okSize('name', 200);
      // Admin (email-based) can change anything incl. role; the user themself
      // can update their profile but NOT role/isAdmin (prevents self-promotion).
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == uid && notTouchingPrivileged())
      )
        && okSize('avatar', 1000000) && okSize('cover', 1000000)
        && okSize('bio', 2000) && okSize('name', 200);
      allow delete: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      match /savedPosts/{postId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Posts
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid
        && okSize('content', 20000) && okSize('imageUrl', 1000000) && okSize('authorAvatar', 1000000);
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin())
        && unchanged('authorId')
        && okSize('content', 20000) && okSize('imageUrl', 1000000) && okSize('authorAvatar', 1000000);
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid
          && okSize('text', 5000);
        allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin())
          && unchanged('authorId') && okSize('text', 5000);
        allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }

      match /reactions/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    // Follows
    match /follows/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.followerUid == request.auth.uid || isAdmin());
    }

    // Listings (Marketplace) — only SELLER/ADMIN may create.
    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSeller() && request.resource.data.sellerUid == request.auth.uid
        && okSize('img', 1000000);
      allow update: if isSignedIn() && (resource.data.sellerUid == request.auth.uid || isAdmin())
        && unchanged('sellerUid') && okSize('img', 1000000);
      allow delete: if isSignedIn() && (resource.data.sellerUid == request.auth.uid || isAdmin());
    }

    // Carts
    match /carts/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Orders — buyer may create and cancel (status only); admin manages fully.
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.buyerUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.buyerUid == request.auth.uid;
      allow update: if isSignedIn() && unchanged('buyerUid') && (
        isAdmin() ||
        (resource.data.buyerUid == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['status', 'cancelReason', 'updatedAt']))
      );
      allow delete: if isAdmin();
    }

    // Adoptions — contains contact info; require sign-in (app is login-gated).
    match /adoptions/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && okSize('img', 1000000) && okSize('story', 10000) && okSize('contact', 500);
      allow update: if isSignedIn() && (resource.data.posterUid == request.auth.uid || isAdmin())
        && unchanged('posterUid')
        && okSize('img', 1000000) && okSize('story', 10000) && okSize('contact', 500);
      allow delete: if isSignedIn() && (resource.data.posterUid == request.auth.uid || isAdmin());
    }

    // Events — organizer/admin may edit fully; anyone signed-in may only RSVP
    // (change attendeeUids).
    match /events/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && okSize('img', 1000000);
      allow update: if isSignedIn() && unchanged('organizerUid') && (
        resource.data.organizerUid == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeeUids'])
      ) && okSize('img', 1000000);
      allow delete: if isSignedIn() && (resource.data.organizerUid == request.auth.uid || isAdmin());
    }

    // Lost Cats — contains contact info; require sign-in (app is login-gated).
    match /lostcats/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && okSize('img', 1000000) && okSize('contact', 500) && okSize('marks', 5000);
      allow update: if isSignedIn() && (resource.data.posterUid == request.auth.uid || isAdmin())
        && unchanged('posterUid')
        && okSize('img', 1000000) && okSize('contact', 500) && okSize('marks', 5000);
      allow delete: if isSignedIn() && (resource.data.posterUid == request.auth.uid || isAdmin());
    }
  }
}
