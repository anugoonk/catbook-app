rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'anugoonk@gmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      match /savedPosts/{postId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // Posts
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      }

      match /reactions/{uid} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      }
    }

    // Follows
    match /follows/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.followerUid == request.auth.uid || isAdmin());
    }

    // Listings (Marketplace)
    match /listings/{listingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.sellerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.sellerUid == request.auth.uid || isAdmin());
    }

    // Carts
    match /carts/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.buyerUid == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.buyerUid == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.buyerUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Adoptions
    match /adoptions/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.posterUid == request.auth.uid || isAdmin());
    }

    // Events
    match /events/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.organizerUid == request.auth.uid || isAdmin());
    }

    // Lost Cats
    match /lostcats/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.posterUid == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.posterUid == request.auth.uid || isAdmin());
    }

    // Chats
    match /chats/{chatId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;

      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
